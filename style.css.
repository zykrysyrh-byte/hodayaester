:root {
    --deep-green: #1b3022;
    --gold: #c5a059;
    --pearl: #fdfaf7;
    --text: #2c2c2c;
}

body {
    font-family: 'Assistant', sans-serif;
    background-color: var(--pearl);
    color: var(--text);
    margin: 0;
    line-height: 1.8;
}

.bg-pattern {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background-image: linear-gradient(rgba(212, 175, 89, 0.03) 1px, transparent 1px),
                      linear-gradient(90deg, rgba(212, 175, 89, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    z-index: -1;
}

header {
    background-color: var(--deep-green);
    color: white;
    padding: 60px 20px 100px 20px; /* השארתי מקום לתמונה שתעלה על זה */
    text-align: center;
    border-bottom: 5px solid var(--gold);
}

h1, h2 {
    font-family: 'Playfair Display', serif;
}

.hero-section {
    max-width: 800px;
    margin: -70px auto 50px; /* התמונה והקופסה עולים קצת על הראש הירוק */
    background: white;
    padding: 40px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    border-radius: 15px;
    text-align: center;
    position: relative;
    z-index: 10;
}

/* התיקון הקריטי לתמונה */
.profile-img {
    width: 180px;      /* גודל קבוע ונעים לעין */
    height: 180px;     /* גובה זהה כדי ליצור עיגול */
    object-fit: cover; /* מבטיח שהתמונה לא תימרח אלא תיחתך יפה */
    border-radius: 50%; /* הופך את התמונה לעיגול מושלם */
    border: 4px solid white;
    box-shadow: 0 5px 15px rgba(0,0,0,0.15);
    margin-top: -110px; /* מושך את התמונה חצי למעלה על הרקע הירוק */
    margin-bottom: 20px;
    background-color: white; /* אם התמונה שקופה, שיהיה רקע לבן */
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    max-width: 1100px;
    margin: auto;
    padding: 20px;
}

.card {
    background: white;
    padding: 30px;
    border-radius: 10px;
    border: 1px solid #eee;
    transition: 0.3s;
    text-align: center;
    position: relative;
}

.card:hover {
    transform: translateY(-5px);
    border-color: var(--gold);
}

.price {
    font-size: 1.6em;
    color: var(--gold);
    font-weight: bold;
    display: block;
    margin: 15px 0;
}

.whatsapp-float {
    position: fixed;
    bottom: 30px;
    left: 30px;
    background: #25d366;
    color: white;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    z-index: 1000;
}

.main-btn {
    background: var(--deep-green);
    color: white;
    padding: 15px 40px;
    text-decoration: none;
    font-weight: bold;
    border-radius: 5px;
    display: inline-block;
}

footer { text-align: center; padding: 50px; opacity: 0.6; }
